{
  "expo": {
    "name": "Linksy",
    "slug": "linksy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "linksy",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#F7FAF9",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7FAF9"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.linksy.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "backgroundColor": "#F7FAF9",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#F7FAF9"
      },
      "enableProguardInReleaseBuilds": true,        
      "enableShrinkResourcesInReleaseBuilds": true   
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Linksy to use the camera to scan QR codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "611184f4-07cd-476d-a009-eac5b3da865a"
      }
    }
  }
}
