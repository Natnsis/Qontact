{
  "expo": {
    "name": "Linksy",
    "slug": "qontact",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "linksy",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#F2EFEA",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2EFEA"
    },
    "assetBundlePatterns": ["**/*"],
    "android": {
      "package": "com.linksy.app",
      "edgeToEdgeEnabled": true,
      "backgroundColor": "#F2EFEA",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#F2EFEA"
      },
      "permissions": ["android.permission.CAMERA", "android.permission.RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Linksy to use the camera to scan QR codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "611184f4-07cd-476d-a009-eac5b3da865a"
      }
    },
    "ios": {
      "bundleIdentifier": "com.linksy.app"
    }
  }
}
